# Copiez vers .env à la racine du projet (à côté de /config, /app).
# Ne commitez pas .env.

# --- Ollama (IA locale) — https://ollama.com
# 1) Installez Ollama, puis dans un terminal : ollama pull llama3.2
# 2) Laissez ollama tourner (icône Windows ou : ollama serve)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
